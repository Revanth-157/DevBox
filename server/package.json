{
  "name": "devbox-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate dev --name init",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.1",
    "cors": "^2.8.0",
    "dotenv": "^16.4.3",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.0.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/supertest": "^2.0.13",
    "prisma": "^6.0.0",
    "supertest": "^6.3.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.3",
    "vitest": "^1.5.2"
  },
  "main": "index.js",
  "keywords": [],
